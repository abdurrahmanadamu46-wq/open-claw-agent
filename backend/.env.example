# Core runtime
PORT=38789
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
JWT_SECRET=replace_with_at_least_16_chars_secret

# LLM upstream (required by backend startup)
NEW_API_BASE_URL=http://127.0.0.1:9999
# NEW_API_TOKEN=optional_in_development_required_in_staging_production

# Default login users for /auth/login
APP_USERS_JSON=[{"username":"admin","password":"change_me","tenant_id":"tenant_demo","roles":["admin"]}]

# AI subservice proxy (backend -> dragon-senate-saas-v2)
DRAGON_AI_BASE_URL=http://127.0.0.1:8000
DRAGON_AI_TIMEOUT_MS=90000
DRAGON_AI_SERVICE_USERNAME=admin
DRAGON_AI_SERVICE_PASSWORD=change_me

# Compliance boundary
COMPLIANCE_REQUIRE_HITL=true
