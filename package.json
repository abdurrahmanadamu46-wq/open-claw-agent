{
  "name": "clawcommerce-agent",
  "version": "1.0.0",
  "description": "ClawCommerce - OpenClaw-based AI operations SaaS agent core",
  "type": "module",
  "main": "dist/run.js",
  "scripts": {
    "build": "tsc && node scripts/copy-templates.cjs",
    "server": "node dist/server/agent-dashboard-server.js",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:agent": "jest src/agent --coverage",
    "test:content": "jest src/content --coverage",
    "test:llm": "cross-env LLM_PROVIDER=mock jest --config jest.config.cjs textsrc/llm --no-coverage",
    "test:radar": "cross-env LLM_PROVIDER=mock jest --config jest.config.cjs textsrc/radar-brain --no-coverage",
    "test:content-factory": "cross-env LLM_PROVIDER=mock VIDEO_RENDERER=mock jest --config jest.config.cjs textsrc/content-factory --no-coverage",
    "test:lobster": "cross-env CAPTCHA_SOLVER=mock jest --config jest.config.cjs textsrc/lobster-base --no-coverage",
    "test:textsrc": "cross-env LLM_PROVIDER=mock VIDEO_RENDERER=mock CAPTCHA_SOLVER=mock jest --config jest.config.cjs textsrc --no-coverage",
    "e2e": "tsx scripts/test-e2e.ts",
    "poc:lobster": "tsx scripts/lobster-client-poc.ts",
    "poc:probe-stream": "tsx scripts/probe-stream-poc.ts",
    "vip:run": "node scripts/vip-build/vip-lobster-entry.cjs",
    "vip:pkg": "pkg scripts/vip-build/vip-lobster-entry.cjs --targets node18-win-x64 --output dist/vip-lobster.exe",
    "vip:release:publish": "node scripts/vip-build/publish-release.cjs",
    "module:help": "powershell -ExecutionPolicy Bypass -File scripts/modules/module.ps1 help",
    "module:ps": "powershell -ExecutionPolicy Bypass -File scripts/modules/module.ps1 ps",
    "module:up:control": "powershell -ExecutionPolicy Bypass -File scripts/modules/module.ps1 up control",
    "module:up:ai": "powershell -ExecutionPolicy Bypass -File scripts/modules/module.ps1 up ai",
    "module:up:ai-heavy": "powershell -ExecutionPolicy Bypass -File scripts/modules/module.ps1 up ai-heavy",
    "module:up:routing": "powershell -ExecutionPolicy Bypass -File scripts/modules/module.ps1 up routing",
    "module:up:monitoring": "powershell -ExecutionPolicy Bypass -File scripts/modules/module.ps1 up monitoring",
    "module:up:all": "powershell -ExecutionPolicy Bypass -File scripts/modules/module.ps1 up all",
    "module:down:control": "powershell -ExecutionPolicy Bypass -File scripts/modules/module.ps1 down control",
    "module:down:all": "powershell -ExecutionPolicy Bypass -File scripts/modules/module.ps1 down all",
    "module:logs:control": "powershell -ExecutionPolicy Bypass -File scripts/modules/module.ps1 logs control",
    "module:test:control": "powershell -ExecutionPolicy Bypass -File scripts/modules/module.ps1 test control",
    "module:test:ai": "powershell -ExecutionPolicy Bypass -File scripts/modules/module.ps1 test ai",
    "module:test:ai-heavy": "powershell -ExecutionPolicy Bypass -File scripts/modules/module.ps1 test ai-heavy",
    "module:test:edge": "powershell -ExecutionPolicy Bypass -File scripts/modules/module.ps1 test edge",
    "module:test:release": "powershell -ExecutionPolicy Bypass -File scripts/modules/module.ps1 test release",
    "docker:data:f:pin": "powershell -ExecutionPolicy Bypass -File scripts/docker/pin-docker-data-to-f.ps1",
    "docker:data:f:pin:cleanup": "powershell -ExecutionPolicy Bypass -File scripts/docker/pin-docker-data-to-f.ps1 -CleanupBackup",
    "backup:f:sync": "powershell -ExecutionPolicy Bypass -File scripts/backup/sync-to-f.ps1",
    "backup:f:sync:verbose": "powershell -ExecutionPolicy Bypass -File scripts/backup/sync-to-f.ps1 -VerboseLog",
    "handover:snapshot": "powershell -ExecutionPolicy Bypass -File scripts/handover/handover_snapshot.ps1",
    "contracts:validate": "python scripts/contracts/validate_contracts.py",
    "compliance:pack": "python scripts/compliance/generate_icp_package.py",
    "compliance:validate:icp": "python scripts/compliance/validate_icp_profile.py",
    "preflight:payment": "python dragon-senate-saas-v2/scripts/preflight_payment_provider.py --env-file dragon-senate-saas-v2/.env --require-live",
    "preflight:notifications": "python dragon-senate-saas-v2/scripts/preflight_notification_channels.py --env-file dragon-senate-saas-v2/.env --require-live",
    "preflight:feishu": "python dragon-senate-saas-v2/scripts/preflight_feishu_callback.py --env-file dragon-senate-saas-v2/.env",
    "system:cleanup:caches": "powershell -ExecutionPolicy Bypass -File scripts/system/cleanup-user-caches.ps1",
    "system:cleanup:caches:apply": "powershell -ExecutionPolicy Bypass -File scripts/system/cleanup-user-caches.ps1 -Apply",
    "system:migrate:workspace:backup": "powershell -ExecutionPolicy Bypass -File scripts/backup/sync-to-f.ps1",
    "quality:utf8": "python scripts/quality/scan_utf8.py",
    "compose:dev:up": "powershell -ExecutionPolicy Bypass -File scripts/compose/profile.ps1 -Profile dev -Action up",
    "compose:dev:config": "powershell -ExecutionPolicy Bypass -File scripts/compose/profile.ps1 -Profile dev -Action config",
    "compose:staging:config": "powershell -ExecutionPolicy Bypass -File scripts/compose/profile.ps1 -Profile staging -Action config",
    "compose:prod:config": "powershell -ExecutionPolicy Bypass -File scripts/compose/profile.ps1 -Profile prod -Action config",
    "apps:help": "powershell -ExecutionPolicy Bypass -File scripts/apps/apps.ps1 help",
    "apps:ps": "powershell -ExecutionPolicy Bypass -File scripts/apps/apps.ps1 ps",
    "apps:up:web": "powershell -ExecutionPolicy Bypass -File scripts/apps/apps.ps1 up web",
    "apps:up:backend": "powershell -ExecutionPolicy Bypass -File scripts/apps/apps.ps1 up backend",
    "apps:up:ai": "powershell -ExecutionPolicy Bypass -File scripts/apps/apps.ps1 up ai",
    "apps:up:ai-heavy": "powershell -ExecutionPolicy Bypass -File scripts/apps/apps.ps1 up ai-heavy",
    "apps:up:all": "powershell -ExecutionPolicy Bypass -File scripts/apps/apps.ps1 up all",
    "apps:down:web": "powershell -ExecutionPolicy Bypass -File scripts/apps/apps.ps1 down web",
    "apps:down:backend": "powershell -ExecutionPolicy Bypass -File scripts/apps/apps.ps1 down backend",
    "apps:down:ai": "powershell -ExecutionPolicy Bypass -File scripts/apps/apps.ps1 down ai",
    "apps:down:ai-heavy": "powershell -ExecutionPolicy Bypass -File scripts/apps/apps.ps1 down ai-heavy",
    "apps:down:all": "powershell -ExecutionPolicy Bypass -File scripts/apps/apps.ps1 down all",
    "apps:logs:web": "powershell -ExecutionPolicy Bypass -File scripts/apps/apps.ps1 logs web",
    "apps:logs:backend": "powershell -ExecutionPolicy Bypass -File scripts/apps/apps.ps1 logs backend",
    "apps:logs:ai": "powershell -ExecutionPolicy Bypass -File scripts/apps/apps.ps1 logs ai",
    "apps:logs:ai-heavy": "powershell -ExecutionPolicy Bypass -File scripts/apps/apps.ps1 logs ai-heavy",
    "apps:dev:web": "powershell -ExecutionPolicy Bypass -File scripts/apps/apps.ps1 dev web",
    "apps:dev:backend": "powershell -ExecutionPolicy Bypass -File scripts/apps/apps.ps1 dev backend",
    "apps:dev:ai": "powershell -ExecutionPolicy Bypass -File scripts/apps/apps.ps1 dev ai",
    "apps:dev:edge": "powershell -ExecutionPolicy Bypass -File scripts/apps/apps.ps1 dev edge",
    "apps:dev:desktop": "npm --prefix apps/desktop-client run tauri:dev",
    "apps:build:desktop": "npm --prefix apps/desktop-client run tauri:build",
    "apps:test:web": "powershell -ExecutionPolicy Bypass -File scripts/apps/apps.ps1 test web",
    "apps:test:backend": "powershell -ExecutionPolicy Bypass -File scripts/apps/apps.ps1 test backend",
    "apps:test:ai": "powershell -ExecutionPolicy Bypass -File scripts/apps/apps.ps1 test ai",
    "apps:test:edge": "powershell -ExecutionPolicy Bypass -File scripts/apps/apps.ps1 test edge",
    "apps:test:all": "powershell -ExecutionPolicy Bypass -File scripts/apps/apps.ps1 test all"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "bullmq": "^5.1.0",
    "dotenv": "^16.3.1",
    "ioredis": "^5.3.2",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "ws": "^8.16.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.0",
    "@types/uuid": "^9.0.7",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "cross-env": "^10.1.0",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.1",
    "socket.io-client": "^4.8.3",
    "ts-jest": "^29.1.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
