# Mock 数据（无后端时设为 true）
NEXT_PUBLIC_USE_MOCK=true
# 后端 API 根地址（联调时填写）
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# MQTT Broker WebSocket（龙虾池实时 / 指令下发）
# 示例：wss://your-broker:8084/mqtt
# NEXT_PUBLIC_MQTT_URL=

# 探针 Relay：Dashboard 连同一 Gateway，join frontend_tenant_* 后收 probe.render
# 示例：http://localhost:3000/agent-cc（与 Agent 同 namespace，由服务端区分连接类型并进房）
# NEXT_PUBLIC_PROBE_RELAY_URL=
