# Demo mode switch (must be explicit)
# true: UI-only mock mode
# false: call real backend APIs
NEXT_PUBLIC_USE_MOCK=false

# API base URL for backend
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:38789

# Runtime environment used by fail-fast policy: development | staging | production
NEXT_PUBLIC_RUNTIME_ENV=development

# Dashboard-only fallback to mock data when live API fails (non-demo mode)
NEXT_PUBLIC_DASHBOARD_ALLOW_MOCK_FALLBACK=false

# Optional external AI keys
# OPENAI_API_KEY=sk-...
# ZHIPU_API_KEY=...

# MQTT Broker WebSocket URL
# NEXT_PUBLIC_MQTT_URL=wss://your-broker:8084/mqtt

# Probe relay URL
# NEXT_PUBLIC_PROBE_RELAY_URL=http://localhost:3000/agent-cc
