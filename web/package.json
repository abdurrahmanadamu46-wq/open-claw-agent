{
  "name": "clawcommerce-web",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "prebuild": "node scripts/clean-next-artifacts.cjs",
    "dev": "next dev -p 3001",
    "dev:3000": "next dev -p 3000",
    "generate-api": "npx openapi-typescript http://localhost:3001/api-json -o src/api/generated/schema.d.ts",
    "generate-api:file": "npx openapi-typescript ../backend/openapi.json -o src/api/generated/schema.d.ts",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test:e2e": "playwright test",
    "test:e2e:ci": "playwright test --reporter=line",
    "test:e2e:live": "playwright test -c playwright.live.config.ts --reporter=line e2e/live-release-regression.spec.ts",
    "test:e2e:release": "node e2e/run-live-release-e2e.cjs"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.3.4",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@tanstack/react-query": "^5.17.0",
    "@tanstack/react-table": "^8.21.3",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "axios": "^1.6.5",
    "framer-motion": "^11.18.2",
    "lucide-react": "^0.577.0",
    "mqtt": "^5.15.0",
    "next": "14.2.0",
    "next-intl": "^4.8.4",
    "posthog-js": "^1.364.6",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.49.3",
    "recharts": "^2.12.0",
    "socket.io-client": "^4.8.3",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "autoprefixer": "^10.4.17",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.0",
    "openapi-typescript": "^7.13.0",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.3.3"
  }
}
