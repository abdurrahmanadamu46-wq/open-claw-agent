  "riskPolicies": {
    "L0": {
      "requiresCommanderSupervision": false,
      "requiresHumanReview": false,
      "approvalActions": [],
      "budgetMultiplier": 1,
      "parallelismCap": null
    },
    "L1": {
      "requiresCommanderSupervision": false,
      "requiresHumanReview": false,
      "approvalActions": [],
      "budgetMultiplier": 1,
      "parallelismCap": null
    },
    "L2": {
      "requiresCommanderSupervision": true,
      "requiresHumanReview": false,
      "approvalActions": ["publish_external", "bulk_message", "outbound_call", "price_commitment", "sensitive_claims"],
      "budgetMultiplier": 0.95,
      "parallelismCap": 2
    },
    "L3": {
      "requiresCommanderSupervision": true,
      "requiresHumanReview": true,
      "approvalActions": ["publish_external", "bulk_message", "outbound_call", "price_commitment", "sensitive_claims", "high_risk_customer_touchpoint"],
      "budgetMultiplier": 0.8,
      "parallelismCap": 1
    }
  },
  "stopLossProfiles": {
    "fast": {
      "maxRetry": 1,
      "maxBudgetOverrunRatio": 1.1,
      "killOnRepeatedFailure": true,
      "freezeOnApprovalReject": true
    },
    "standard": {
      "maxRetry": 2,
      "maxBudgetOverrunRatio": 1.2,
      "killOnRepeatedFailure": true,
      "freezeOnApprovalReject": true
    },
    "strict": {
      "maxRetry": 2,
      "maxBudgetOverrunRatio": 1.05,
      "killOnRepeatedFailure": true,
      "freezeOnApprovalReject": true
    }
  },
  "arbitrationPriority": [
    "platform_governance",
    "tenant_policy",
    "risk_boundary",
    "revenue_value",
    "latency_priority",
    "expression_strength"
  ],
  "overrideRules": [
    {
      "id": "route_to_recon_when_evidence_low",
      "enabled": true,
      "priority": 90,
      "weight": 1,
      "tags": ["evidence", "routing"],
      "notes": "Force evidence recovery before expensive execution paths.",
      "when": {
        "evidenceSufficiency": ["low"],
        "missionType": ["content_production", "lead_qualification", "conversion_push"]
      },
      "effects": {
        "prependLineups": ["reconnaissance"],
        "prependStages": [
          { "stageId": "scan", "label": "Backfill evidence", "ownerRole": "radar", "lineupId": "reconnaissance", "parallelAllowed": true },
          { "stageId": "route", "label": "Reframe route", "ownerRole": "strategist", "lineupId": "reconnaissance", "parallelAllowed": false }
        ],
        "reasons": ["Evidence is weak, so Commander inserts reconnaissance before execution-heavy work."]
      }
    },
    {
      "id": "promote_conversion_for_warm_high_value_leads",
      "enabled": true,
      "priority": 80,
      "weight": 1.2,
      "tags": ["warm-lead", "revenue", "latency"],
      "notes": "Fast-track warm leads into the conversion lane.",
      "when": {
        "missionType": ["interaction_handling", "lead_qualification"],
        "revenueImpact": ["high", "strategic"],
        "latencyPriority": ["high", "urgent"],
        "hasWarmLead": true
      },
      "effects": {
        "appendLineups": ["conversion"],
        "appendStages": [
          { "stageId": "followup", "label": "Escalate warm lead", "ownerRole": "followup", "lineupId": "conversion", "parallelAllowed": false }
        ],
        "reasons": ["Warm, high-value lead needs a faster conversion lane."]
      }
    },
    {
      "id": "force_recovery_on_instability",
      "enabled": true,
      "priority": 100,
      "weight": 2,
      "tags": ["stability", "recovery"],
      "notes": "External instability overrides business intent.",
      "when": {
        "externalDependencyUnstable": true
      },
      "effects": {
        "replaceLineups": ["recovery"],
        "replaceStagesFromMission": "recovery_replay",
        "reasons": ["External dependency is unstable, so Commander routes to recovery."]
      }
    },
    {
      "id": "force_recovery_on_repeated_failures",
      "enabled": true,
      "priority": 95,
      "weight": 1.6,
      "tags": ["stability", "retry"],
      "notes": "Repeated failures require supervised recovery.",
      "when": {
        "recentFailureCountAtLeast": 2
      },
      "effects": {
        "appendLineups": ["recovery"],
        "reasons": ["Repeated failures trigger recovery supervision."]
      }
    },
    {
      "id": "insert_approval_for_external_action",
      "enabled": true,
      "priority": 85,
      "weight": 1.1,
      "tags": ["approval", "external-action"],
      "notes": "Any external execution should be explicitly governed.",
      "when": {
        "requiresExternalAction": true
      },
      "effects": {
        "addApprovalActions": ["publish_external"],
        "forceCommanderSupervision": true,
        "reasons": ["External execution requires explicit approval and supervision."]
      }
    },
    {
      "id": "insert_approval_for_human_touchpoint",
      "enabled": true,
      "priority": 88,
      "weight": 1.15,
      "tags": ["approval", "human-touchpoint"],
      "notes": "Human touchpoints carry brand and compliance risk.",
      "when": {
        "requiresHumanTouchpoint": true
      },
      "effects": {
        "addApprovalActions": ["outbound_call", "high_risk_customer_touchpoint"],
        "forceCommanderSupervision": true,
        "reasons": ["Human touchpoints can create trust or risk, so approval is required."]
      }
    },
    {
      "id": "tighten_budget_when_urgent_and_high_risk",
      "enabled": true,
      "priority": 70,
      "weight": 0.9,
      "tags": ["budget", "risk", "latency"],
      "notes": "Urgency under high risk needs a narrower operating envelope.",
      "when": {
        "latencyPriority": ["urgent"],
        "riskLevel": ["L2", "L3"]
      },
      "effects": {
        "budgetMultiplier": 0.9,
        "parallelismCap": 1,
        "reasons": ["Urgent and high-risk tasks need a tighter control envelope."]
      }
    }
  ]
}
