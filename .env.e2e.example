# 无头 E2E 联调 (PM v1.14) — 复制为 .env 后填入真实值
# 运行: npm run e2e

# 后端 Base URL（与前端 NEXT_PUBLIC_API_BASE_URL 一致）
E2E_API_BASE_URL=http://localhost:3000

# 商家端 JWT，用于 POST/GET /api/v1/campaigns、/api/v1/leads
# 可从前端登录后从 localStorage / 抓包获取，或由后端提供测试 Token
E2E_JWT=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# 当前租户 ID（与 JWT 中的 tenant 一致），用于 Step 4 内部线索回传
E2E_TENANT_ID=tenant-uuid-here

# 与后端 .env 中的 INTERNAL_API_SECRET 完全一致，否则 POST /api/internal/leads 会 403
INTERNAL_API_SECRET=your-internal-secret-from-backend-env
