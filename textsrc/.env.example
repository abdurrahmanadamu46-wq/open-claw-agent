# ========== ClawCommerce textsrc 框架 — 环境变量示例 ==========
# 复制本文件为 .env 后按需填写；切换模型/API 仅改此处，无需改业务代码。

# ---------- 大模型（必先配置其一或 mock） ----------
LLM_PROVIDER=deepseek
# 可选: openai | grok | mock

# DeepSeek（OpenAI 兼容）
DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat

# OpenAI
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o

# Grok (xAI)
# XAI_API_KEY=
# GROK_MODEL=grok-2

# ---------- ASR（语音/视频转文字） ----------
ASR_PROVIDER=mock
# 后续: aliyun | whisper | tongyi

# ---------- 视频渲染 ----------
VIDEO_RENDERER=mock
# 后续: heygen | tencent

# ---------- 去水印（合规：Pipeline removeWatermark=true 时使用） ----------
WATERMARK_REMOVER=mock
# 后续: internal | 第三方

# ---------- 打码平台 ----------
CAPTCHA_SOLVER=mock
# 后续: 2captcha | anticaptcha | tujian

# ---------- 龙虾底座 ----------
# 多账号 Profile 根目录（Cookie/缓存隔离）
# LOBSTER_PROFILE_ROOT=.lobster-profiles

# ---------- 任务队列 / 总控（可选，供 worker 或后端用） ----------
# REDIS_URL=redis://localhost:6380
