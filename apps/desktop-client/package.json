{
  "name": "tauri-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "runtime:sync": "powershell -ExecutionPolicy Bypass -File scripts/sync-runtime.ps1",
    "runtime:manifest:sign": "python scripts/sign-runtime-manifest.py --out runtime/updates/stable.json",
    "tauri": "tauri",
    "tauri:dev": "npm run runtime:sync && tauri dev",
    "tauri:build": "npm run runtime:sync && tauri build"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "@tauri-apps/cli": "^2"
  }
}
