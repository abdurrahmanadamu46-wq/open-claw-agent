{"industry":"文旅休闲_露营基地","lobster_id":"abacus","pack_type":"scoring-features","version":"v1","items":[{"id":"camping_abacus_short_term","feature_name":"短期预订转化概率","metric":"conversion_probability","weight":0.22,"scoring_rule":"日期、人数、营位形式和下一步动作越清楚，短期分越高。","positive_signals":["明确周末或具体日期","明确人数和露营形式","愿意继续确认营位"],"negative_signals":["只有泛兴趣","没有日期也没有人数"],"value_guidance":"这是露营基地短期分的核心指标。"},{"id":"camping_abacus_facility","feature_name":"设施就绪度","metric":"facility_readiness","weight":0.18,"scoring_rule":"用户越愿意讨论洗澡、厕所、停车和营位距离，分值越高。","positive_signals":["愿意确认洗澡和热水","愿意看停车和动线"],"negative_signals":["只盯价格和风景","回避所有事实"],"value_guidance":"营地线索的真实到店很依赖基础设施匹配。"},{"id":"camping_abacus_repeat","feature_name":"复游潜力","metric":"repeat_potential","weight":0.18,"scoring_rule":"二刷、会员和主题活动回流越明确，长期分越高。","positive_signals":["上次来过","会员用户","冲新活动"],"negative_signals":["纯一次性围观","无后续兴趣"],"value_guidance":"要重视主题夜和会员带来的复游价值。"},{"id":"camping_abacus_fit","feature_name":"客群与营位匹配度","metric":"fit_clarity","weight":0.14,"scoring_rule":"同行结构和营位越对应，得分越高。","positive_signals":["亲子配拎包入住","团建配多人承接路线"],"negative_signals":["同行结构模糊","营位不匹配"],"value_guidance":"适配越清楚，承接越稳。"},{"id":"camping_abacus_capacity","feature_name":"容量承接匹配度","metric":"capacity_fit","weight":0.12,"scoring_rule":"营位、停车和客服承接越匹配，分值越高。","positive_signals":["营位余量和承接可控","客服跟进及时"],"negative_signals":["周末营位紧张","客服接不住"],"value_guidance":"容量不足时必须压住表面高热线索。"},{"id":"camping_abacus_risk","feature_name":"风险扣分","metric":"risk_penalty","weight":0.16,"scoring_rule":"天气无影响、绝对方便和明火无条件诉求越强，扣分越多。","positive_signals":["接受真实边界","接受天气和禁火规则"],"negative_signals":["要求下雨也不受影响","要求明火随便用"],"value_guidance":"风险失控时，宁可放弃，也不要误判高价值。"}]}
