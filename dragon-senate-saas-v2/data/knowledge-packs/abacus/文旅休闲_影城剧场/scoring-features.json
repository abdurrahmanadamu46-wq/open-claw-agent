{"industry":"文旅休闲_影城剧场","lobster_id":"abacus","pack_type":"scoring-features","version":"v1","items":[{"id":"cinema_abacus_short_term","feature_name":"短期购票转化概率","metric":"conversion_probability","weight":0.22,"scoring_rule":"场次、片单、产品和下一步动作越清楚，短期分越高。","positive_signals":["明确周末或具体场次","明确片单或剧目","愿意继续确认产品"],"negative_signals":["只有泛兴趣","没有时间也没有片单"],"value_guidance":"这是影城剧场短期分的核心指标。"},{"id":"cinema_abacus_experience","feature_name":"到场体验就绪度","metric":"experience_readiness","weight":0.18,"scoring_rule":"用户越愿意讨论停车、取票、视野和入场边界，分值越高。","positive_signals":["愿意确认停车和视野","愿意看到场说明"],"negative_signals":["只盯价格","回避所有事实"],"value_guidance":"门店线索的真实到店很依赖到场匹配。"},{"id":"cinema_abacus_repeat","feature_name":"会员回流潜力","metric":"repeat_potential","weight":0.18,"scoring_rule":"会员复购、影迷二刷和老观众回流越明确，长期分越高。","positive_signals":["会员活跃","二刷意向","老观众回流"],"negative_signals":["纯一次性围观","无后续兴趣"],"value_guidance":"要重视回流和复购带来的长期价值。"},{"id":"cinema_abacus_fit","feature_name":"客群与产品匹配度","metric":"fit_clarity","weight":0.14,"scoring_rule":"时间和产品越对应，得分越高。","positive_signals":["情侣配晚场","亲子配白天动画场"],"negative_signals":["需求模糊","产品不匹配"],"value_guidance":"适配越清楚，承接越稳。"},{"id":"cinema_abacus_capacity","feature_name":"容量承接匹配度","metric":"capacity_fit","weight":0.12,"scoring_rule":"场次、余位和检票承接越匹配，分值越高。","positive_signals":["余位和承接可控","客服跟进及时"],"negative_signals":["晚场满场","检票高峰压力大"],"value_guidance":"容量不足时必须压住表面高热线索。"},{"id":"cinema_abacus_risk","feature_name":"风险扣分","metric":"risk_penalty","weight":0.16,"scoring_rule":"随时退票、绝对好位置和绝对不排队诉求越强，扣分越多。","positive_signals":["接受真实边界","接受正常退改规则"],"negative_signals":["要求随时退","要求绝对不排队"],"value_guidance":"风险失控时，宁可放弃，也不要误判高价值。"}]}
