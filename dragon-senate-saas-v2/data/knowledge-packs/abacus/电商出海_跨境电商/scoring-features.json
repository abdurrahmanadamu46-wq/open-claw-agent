{"industry":"电商出海_跨境电商","lobster_id":"abacus","pack_type":"scoring-features","version":"v1","items":[{"id":"crossborder_abacus_short_term","feature_name":"短期转化概率","metric":"conversion_probability","weight":0.22,"scoring_rule":"平台、站点、类目和下一步动作越清楚，短期分越高。","positive_signals":["明确平台和国家站点","明确类目和 SKU","愿意继续确认路线"],"negative_signals":["只有泛兴趣","没有站点也没有类目"],"value_guidance":"这是跨境电商短期分的核心指标。"},{"id":"crossborder_abacus_logistics","feature_name":"履约就绪度","metric":"fulfillment_readiness","weight":0.18,"scoring_rule":"用户越愿意讨论物流、税费、退货和售后，分值越高。","positive_signals":["愿意确认仓发和税费","愿意看退换货规则"],"negative_signals":["只盯价格","回避所有履约问题"],"value_guidance":"跨境转化很依赖履约与售后匹配。"},{"id":"crossborder_abacus_repeat","feature_name":"复购潜力","metric":"repeat_potential","weight":0.18,"scoring_rule":"补货、订阅和老客回流越明确，长期分越高。","positive_signals":["补货周期明确","有订阅和升级版意向"],"negative_signals":["纯一次性围观","无后续兴趣"],"value_guidance":"要重视补货和回流带来的长期价值。"},{"id":"crossborder_abacus_fit","feature_name":"市场与内容匹配度","metric":"fit_clarity","weight":0.14,"scoring_rule":"站点和内容越对应，得分越高。","positive_signals":["美国站配英语素材","德国站配本地化说明"],"negative_signals":["市场模糊","内容不匹配"],"value_guidance":"适配越清楚，承接越稳。"},{"id":"crossborder_abacus_capacity","feature_name":"履约承接匹配度","metric":"capacity_fit","weight":0.12,"scoring_rule":"库存、物流和客服承接越匹配，分值越高。","positive_signals":["库存和承接可控","客服跟进及时"],"negative_signals":["缺货仍强推","客服接不住"],"value_guidance":"容量不足时必须压住表面高热线索。"},{"id":"crossborder_abacus_risk","feature_name":"风险扣分","metric":"risk_penalty","weight":0.16,"scoring_rule":"全球包税、极速到货和无限退货诉求越强，扣分越多。","positive_signals":["接受真实边界","接受正常税费与退换规则"],"negative_signals":["要求全球包税","要求极速到货"],"value_guidance":"风险失控时，宁可放弃，也不要误判高价值。"}]}
