      "metric_group": "message_match",
      "feature": "路线区分度",
      "weight": 0.16,
      "definition": "预算代步、家庭 SUV、新能源和豪华升级是否都有不同的视觉语言，而不是所有视频都长得一样。",
      "high_score_signals": [
        "不同路线画面明显不同",
        "问题和场景一一对应",
        "镜头和文案同题"
      ],
      "low_score_signals": [
        "所有路线都只靠口号和外观空镜",
        "场景和问题混乱",
        "看不出适合谁"
      ],
      "score_rule": "路线和场景越匹配，得分越高。"
    },
    {
      "id": "truth_gap_control",
      "metric_group": "brand_safety",
      "feature": "捡漏幻想控制力",
      "weight": 0.18,
      "definition": "视频是否主动通过真实细节、边界和判断逻辑控制用户预期，而不是制造捡漏幻想。",
      "high_score_signals": [
        "真实流程替代低价幻想",
        "边界清楚",
        "不过度夸大车况"
      ],
      "low_score_signals": [
