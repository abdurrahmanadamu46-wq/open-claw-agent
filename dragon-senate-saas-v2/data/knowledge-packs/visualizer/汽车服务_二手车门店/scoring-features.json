        "细节与流程能接上"
      ],
      "low_score_signals": [
        "开场长时间只有海报和广告图",
        "看不出是门店还是素材库",
        "车辆证据太弱"
      ],
      "score_rule": "真实车辆证据越靠前、越连贯，得分越高。"
    },
    {
      "id": "inspection_process_visibility",
      "metric_group": "trust_building",
      "feature": "检测与过程可见度",
      "weight": 0.17,
      "definition": "分镜是否把看车、检测、讲解和试驾串成可信路径，而不是只展示价格和结果感。",
      "high_score_signals": [
        "有检测或看车步骤",
        "有真实讲解准备",
        "有边界或费用说明"
      ],
      "low_score_signals": [
        "只有结果没有过程",
        "步骤跳跃严重",
        "流程看起来像价格秀"
      ],
      "score_rule": "流程越可见、越完整，得分越高。"
    },
    {
