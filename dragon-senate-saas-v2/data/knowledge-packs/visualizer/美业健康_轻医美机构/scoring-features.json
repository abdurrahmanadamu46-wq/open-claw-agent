{
  "industry": "美业健康_轻医美机构",
  "lobster_id": "visualizer",
  "pack_type": "scoring-features",
  "version": "1.0.0",
  "items": [
    {
      "id": "real_environment_visibility",
      "metric_group": "visual_proof_density",
      "feature": "真实环境可见度",
      "weight": 0.16,
      "definition": "分镜是否把本店环境、面诊室和真实流程放在前排位置，而不是依赖海报脸和重修图。",
      "high_score_signals": [
        "前 3 镜内出现环境或面诊室",
        "看得出是本机构真实空间",
        "环境与流程能接上"
      ],
      "low_score_signals": [
        "开场长时间只有海报和广告脸",
        "看不出是机构还是广告棚拍",
        "空间证据太弱"
      ],
      "score_rule": "真实空间证据越靠前、越连贯，得分越高。"
    },
    {
      "id": "consult_process_visibility",
      "metric_group": "trust_building",
      "feature": "面诊与过程可见度",
      "weight": 0.17,
      "definition": "分镜是否把咨询、判断、准备和术后说明串成可信流程，而不是只展示结果感。",
      "high_score_signals": [
        "有面诊或判断步骤",
        "有真实流程准备",
        "有边界或术后说明"
      ],
      "low_score_signals": [
        "只有结果没有过程",
        "步骤跳跃严重",
        "流程看起来像效果秀"
      ],
      "score_rule": "流程越可见、越完整，得分越高。"
    },
    {
      "id": "route_distinction",
      "metric_group": "message_match",
      "feature": "路线区分度",
      "weight": 0.16,
      "definition": "问题型咨询、节前焕新、复查维护和首次信任路线是否都有不同的视觉语言，而不是所有视频都长得一样。",
      "high_score_signals": [
        "不同路线画面明显不同",
        "问题和场景一一对应",
        "镜头和文案同题"
      ],
      "low_score_signals": [
        "所有路线都只靠环境和精修脸",
        "场景和问题混乱",
        "看不出适合谁"
      ],
      "score_rule": "路线和场景越匹配，得分越高。"
    },
    {
      "id": "truth_gap_control",
      "metric_group": "brand_safety",
      "feature": "结果幻想控制力",
      "weight": 0.18,
      "definition": "视频是否主动通过真实流程、边界和判断逻辑控制用户预期，而不是制造神奇改变幻想。",
      "high_score_signals": [
        "真实流程替代强对比图幻想",
        "边界清楚",
        "不过度夸大恢复与结果"
      ],
      "low_score_signals": [
        "大量对比图感视觉",
        "看不出边界",
        "效果被过度理想化"
      ],
      "score_rule": "越能控制结果幻想，品牌安全得分越高。"
    },
    {
      "id": "booking_path_visibility",
      "metric_group": "conversion_readiness",
      "feature": "预约路径可见度",
      "weight": 0.15,
      "definition": "内容是否留出预约、前台、时段或面诊说明的承接，而不是只拍环境和脸部细节。",
      "high_score_signals": [
        "后半段出现预约承接画面",
        "CTA 与画面一致",
        "时段或咨询范围可感知"
      ],
      "low_score_signals": [
        "没有任何下一步",
        "只剩氛围展示",
        "CTA 与画面脱节"
      ],
      "score_rule": "观众越容易知道如何预约，得分越高。"
    },
    {
      "id": "respectful_face_representation",
      "metric_group": "brand_safety",
      "feature": "面部尊重感",
      "weight": 0.18,
      "definition": "分镜是否尊重不同状态和困扰，不用羞辱式拍法制造焦虑。",
      "high_score_signals": [
        "镜头克制",
        "判断导向而非羞辱导向",
        "问题近景处理得当"
      ],
      "low_score_signals": [
        "放大瑕疵逼单",
        "羞辱式对比",
        "吓人问题图主导内容"
      ],
      "score_rule": "越能守住尊重感，品牌安全得分越高。"
    }
  ]
}
