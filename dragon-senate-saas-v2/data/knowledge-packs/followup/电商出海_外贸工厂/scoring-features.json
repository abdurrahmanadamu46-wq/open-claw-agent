{"industry":"电商出海_外贸工厂","lobster_id":"followup","pack_type":"scoring-features","version":"1.0.0","items":[{"id":"factory_followup_market_product","metric_group":"qualification","feature":"市场与产品补齐率","weight":0.22,"definition":"市场、产品、模式和问题方向越清楚，跟进成功率越高。","high_score_signals":["市场明确","产品明确","模式明确"],"low_score_signals":["只有想找工厂","市场和产品都模糊"],"score_rule":"市场和产品都明确时为高分。"},{"id":"factory_followup_route","metric_group":"qualification","feature":"合作路线确认度","weight":0.18,"definition":"OEM、ODM、现货和返单路线方向越清楚，后续建议越稳。","high_score_signals":["明确偏好 OEM 或试样","明确先打样还是直接量产"],"low_score_signals":["都行","没想好怎么做"],"score_rule":"偏好和路线可对应时高分。"},{"id":"factory_followup_trade","metric_group":"timing","feature":"交付节奏成熟度","weight":0.16,"definition":"用户越能接受根据 MOQ、交期和条款调整方案，跟进成功率越高。","high_score_signals":["接受交期分级","接受条款与付款差异"],"low_score_signals":["要求任何产品都快","拒绝任何调整"],"score_rule":"接受履约分支时高分。"},{"id":"factory_followup_quality","metric_group":"experience","feature":"品质需求清晰度","weight":0.16,"definition":"认证、质检和售后要求越清楚，后续建议越有效。","high_score_signals":["明确认证要求","明确验厂和质保要求"],"low_score_signals":["不清楚自己在意什么","只看价格"],"score_rule":"品质需求和市场同时明确时高分。"},{"id":"factory_followup_repeat","metric_group":"retention","feature":"返单潜力","weight":0.14,"definition":"上次合作反馈和这次返单或升级兴趣越明确，返单价值越高。","high_score_signals":["提到上次交付体验","提到这次返单或升级"],"low_score_signals":["没有任何新理由","纯泛回访"],"score_rule":"上次体验和这次新理由同时明确时高分。"},{"id":"factory_followup_risk","metric_group":"risk","feature":"边界风险","weight":0.14,"definition":"MOQ、交期和付款上的绝对诉求越强，风险越高。","high_score_signals":["接受真实边界","接受正常付款与交期规则"],"low_score_signals":["要求极低 MOQ","要求长账期"],"score_rule":"接受真实边界时高分。"}]}
