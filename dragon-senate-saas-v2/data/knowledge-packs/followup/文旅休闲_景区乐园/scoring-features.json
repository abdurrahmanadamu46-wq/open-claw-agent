{"industry":"文旅休闲_景区乐园","lobster_id":"followup","pack_type":"scoring-features","version":"1.0.0","items":[{"id":"park_followup_date_group","metric_group":"qualification","feature":"日期与同行补齐率","weight":0.22,"definition":"日期、人数和孩子年龄越清楚，跟进成功率越高。","high_score_signals":["日期明确","几大几小明确","孩子年龄明确"],"low_score_signals":["只有想去看看","同行结构模糊"],"score_rule":"日期和同行结构都明确时为高分。"},{"id":"park_followup_route","metric_group":"qualification","feature":"路线确认度","weight":0.18,"definition":"亲子、夜场、轻松逛和团建方向越清楚，后续推荐越稳。","high_score_signals":["明确偏好夜场或亲子","明确更想玩项目还是看演出"],"low_score_signals":["都行","没想好怎么玩"],"score_rule":"偏好和票种可对应时高分。"},{"id":"park_followup_weather","metric_group":"timing","feature":"天气应对成熟度","weight":0.16,"definition":"用户越能接受根据天气切换路线，跟进成功率越高。","high_score_signals":["愿意按天气换路线","接受室内或夜场替代"],"low_score_signals":["要求任何天气都一样","拒绝任何替代"],"score_rule":"接受分支路线时高分。"},{"id":"park_followup_arrival","metric_group":"experience","feature":"到园规划清晰度","weight":0.16,"definition":"到园时间和交通方式越清楚，后续建议越有效。","high_score_signals":["明确自驾或公共交通","明确几点到园"],"low_score_signals":["不清楚怎么去","不清楚几点到"],"score_rule":"到园方式和时间同时明确时高分。"},{"id":"park_followup_repeat","metric_group":"retention","feature":"复游潜力","weight":0.14,"definition":"上次体验反馈和这次新活动兴趣越明确，复游价值越高。","high_score_signals":["提到上次体验","提到这次新增活动"],"low_score_signals":["没有任何新理由","纯泛回访"],"score_rule":"上次体验和这次新理由同时明确时高分。"},{"id":"park_followup_risk","metric_group":"risk","feature":"边界风险","weight":0.14,"definition":"天气、开放时间和绝对体验诉求越强，风险越高。","high_score_signals":["接受当天开放边界","接受真实排队预期"],"low_score_signals":["要求所有项目都开","要求完全不排队"],"score_rule":"接受真实边界时高分。"}]}
