{"industry":"电商出海_跨境电商","lobster_id":"followup","pack_type":"scoring-features","version":"1.0.0","items":[{"id":"crossborder_followup_market_product","metric_group":"qualification","feature":"平台站点与类目补齐率","weight":0.22,"definition":"平台、站点、类目和问题方向越清楚，跟进成功率越高。","high_score_signals":["平台明确","站点明确","类目明确"],"low_score_signals":["只有想做跨境","市场和产品都模糊"],"score_rule":"站点和类目都明确时为高分。"},{"id":"crossborder_followup_route","metric_group":"qualification","feature":"渠道路线确认度","weight":0.18,"definition":"listing、独立站、本地化和售后路线方向越清楚，后续建议越稳。","high_score_signals":["明确偏好平台或独立站","明确更卡转化前还是售后"],"low_score_signals":["都行","没想好怎么做"],"score_rule":"偏好和路线可对应时高分。"},{"id":"crossborder_followup_logistics","metric_group":"timing","feature":"履约节奏成熟度","weight":0.16,"definition":"用户越能接受根据物流和税费边界调整方案，跟进成功率越高。","high_score_signals":["接受时效分级","接受税费与仓发差异"],"low_score_signals":["要求任何国家都快","拒绝任何调整"],"score_rule":"接受履约分支时高分。"},{"id":"crossborder_followup_service","metric_group":"experience","feature":"售后需求清晰度","weight":0.16,"definition":"退款、拒付和客服承接要求越清楚，后续建议越有效。","high_score_signals":["明确售后顾虑","明确时区和客服要求"],"low_score_signals":["不清楚自己在意什么","只看增长承诺"],"score_rule":"售后需求和市场同时明确时高分。"},{"id":"crossborder_followup_repeat","metric_group":"retention","feature":"复购潜力","weight":0.14,"definition":"上次购买反馈和这次补货或升级兴趣越明确，复购价值越高。","high_score_signals":["提到上次体验","提到这次补货或升级"],"low_score_signals":["没有任何新理由","纯泛回访"],"score_rule":"上次体验和这次新理由同时明确时高分。"},{"id":"crossborder_followup_risk","metric_group":"risk","feature":"边界风险","weight":0.14,"definition":"时效、税费和退换货上的绝对诉求越强，风险越高。","high_score_signals":["接受真实边界","接受正常退换规则"],"low_score_signals":["要求全球包税","要求无限退货"],"score_rule":"接受真实边界时高分。"}]}
