{"industry":"文旅休闲_露营基地","lobster_id":"followup","pack_type":"scoring-features","version":"1.0.0","items":[{"id":"camping_followup_date_people","metric_group":"qualification","feature":"日期与人数补齐率","weight":0.22,"definition":"出行日期、人数和孩子年龄越清楚，跟进成功率越高。","high_score_signals":["日期明确","人数明确","孩子年龄明确"],"low_score_signals":["只有想去露营","同行结构模糊"],"score_rule":"日期和人数都明确时为高分。"},{"id":"camping_followup_route","metric_group":"qualification","feature":"露营形式确认度","weight":0.18,"definition":"自搭、拎包入住、房车和日营方向越清楚，后续建议越稳。","high_score_signals":["明确偏好拎包入住或自搭","明确过夜还是日营"],"low_score_signals":["都行","没想好怎么玩"],"score_rule":"偏好和营位可对应时高分。"},{"id":"camping_followup_weather","metric_group":"timing","feature":"天气应对成熟度","weight":0.16,"definition":"用户越能接受根据天气切换路线，跟进成功率越高。","high_score_signals":["愿意按天气换路线","接受改期或日营替代"],"low_score_signals":["要求任何天气都一样","拒绝任何替代"],"score_rule":"接受分支路线时高分。"},{"id":"camping_followup_facility","metric_group":"experience","feature":"设施需求清晰度","weight":0.16,"definition":"洗澡、厕所、停车和供电要求越清楚，后续建议越有效。","high_score_signals":["明确热水和厕所要求","明确到场方式"],"low_score_signals":["不清楚自己在意什么","只看图片"],"score_rule":"设施需求和到场方式同时明确时高分。"},{"id":"camping_followup_repeat","metric_group":"retention","feature":"复游潜力","weight":0.14,"definition":"上次体验反馈和这次新活动兴趣越明确，复游价值越高。","high_score_signals":["提到上次体验","提到这次新增活动"],"low_score_signals":["没有任何新理由","纯泛回访"],"score_rule":"上次体验和这次新理由同时明确时高分。"},{"id":"camping_followup_risk","metric_group":"risk","feature":"边界风险","weight":0.14,"definition":"天气、禁火和绝对体验诉求越强，风险越高。","high_score_signals":["接受真实边界","接受天气和禁火规则"],"low_score_signals":["要求绝对不受影响","要求任何情况都能明火"],"score_rule":"接受真实边界时高分。"}]}
