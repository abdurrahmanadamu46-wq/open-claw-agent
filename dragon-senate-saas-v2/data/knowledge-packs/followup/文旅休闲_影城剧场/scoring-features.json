{"industry":"文旅休闲_影城剧场","lobster_id":"followup","pack_type":"scoring-features","version":"1.0.0","items":[{"id":"cinema_followup_time_title","metric_group":"qualification","feature":"场次与片单补齐率","weight":0.22,"definition":"场次时间、片单和产品方向越清楚，跟进成功率越高。","high_score_signals":["场次明确","片单明确","产品方向明确"],"low_score_signals":["只有想看看","时间和片单都模糊"],"score_rule":"时间和片单都明确时为高分。"},{"id":"cinema_followup_route","metric_group":"qualification","feature":"产品路线确认度","weight":0.18,"definition":"普通场、升级厅、剧场和会员路线方向越清楚，后续建议越稳。","high_score_signals":["明确偏好 IMAX 或普通场","明确看电影还是演出"],"low_score_signals":["都行","没想好怎么选"],"score_rule":"偏好和产品可对应时高分。"},{"id":"cinema_followup_schedule","metric_group":"timing","feature":"场次节奏成熟度","weight":0.16,"definition":"用户越能接受根据场次和高峰切换时间段，跟进成功率越高。","high_score_signals":["愿意按场次选时间","接受高峰与错峰建议"],"low_score_signals":["要求任何时间都舒服","拒绝任何调整"],"score_rule":"接受时间分支时高分。"},{"id":"cinema_followup_access","metric_group":"experience","feature":"到场需求清晰度","weight":0.16,"definition":"停车、取票、视野和排队要求越清楚，后续建议越有效。","high_score_signals":["明确停车和视野要求","明确是否介意排队"],"low_score_signals":["不清楚自己在意什么","只看价格"],"score_rule":"到场需求和时间同时明确时高分。"},{"id":"cinema_followup_repeat","metric_group":"retention","feature":"复购潜力","weight":0.14,"definition":"上次体验反馈和这次新片新剧兴趣越明确，复购价值越高。","high_score_signals":["提到上次体验","提到这次新片或新剧目"],"low_score_signals":["没有任何新理由","纯泛回访"],"score_rule":"上次体验和这次新理由同时明确时高分。"},{"id":"cinema_followup_risk","metric_group":"risk","feature":"边界风险","weight":0.14,"definition":"退改、位置和排队上的绝对诉求越强，风险越高。","high_score_signals":["接受真实边界","接受正常退改规则"],"low_score_signals":["要求随时退","要求绝对好位置"],"score_rule":"接受真实边界时高分。"}]}
