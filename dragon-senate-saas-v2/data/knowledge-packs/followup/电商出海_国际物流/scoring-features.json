{"industry":"电商出海_国际物流","lobster_id":"followup","pack_type":"scoring-features","version":"1.0.0","items":[{"id":"intl_logistics_followup_market_goods","metric_group":"qualification","feature":"国家与货型补齐率","weight":0.22,"definition":"国家、货型、模式和问题方向越清楚，跟进成功率越高。","high_score_signals":["国家明确","货型明确","模式明确"],"low_score_signals":["只有想发货","国家和货型都模糊"],"score_rule":"国家和货型都明确时为高分。"},{"id":"intl_logistics_followup_route","metric_group":"qualification","feature":"物流路线确认度","weight":0.18,"definition":"海运、空运、专线和补货路线方向越清楚，后续建议越稳。","high_score_signals":["明确偏好海运或空运","明确先试发还是长期合作"],"low_score_signals":["都行","没想好怎么发"],"scoreRule":"偏好和路线可对应时高分。"},{"id":"intl_logistics_followup_sla","metric_group":"timing","feature":"履约节奏成熟度","weight":0.16,"definition":"用户越能接受根据时效和赔付边界调整方案，跟进成功率越高。","high_score_signals":["接受时效分级","接受赔付与税费差异"],"low_score_signals":["要求任何货都快","拒绝任何调整"],"score_rule":"接受履约分支时高分。"},{"id":"intl_logistics_followup_service","metric_group":"experience","feature":"售后需求清晰度","weight":0.16,"definition":"赔付、查验和客服承接要求越清楚，后续建议越有效。","high_score_signals":["明确异常顾虑","明确客服与查验要求"],"low_score_signals":["不清楚自己在意什么","只看低价"],"score_rule":"售后需求和航线同时明确时高分。"},{"id":"intl_logistics_followup_repeat","metric_group":"retention","feature":"补货潜力","weight":0.14,"definition":"上次合作反馈和这次补货或升级兴趣越明确，补货价值越高。","high_score_signals":["提到上次履约体验","提到这次补货或新航线"],"low_score_signals":["没有任何新理由","纯泛回访"],"score_rule":"上次体验和这次新理由同时明确时高分。"},{"id":"intl_logistics_followup_risk","metric_group":"risk","feature":"边界风险","weight":0.14,"definition":"时效、赔付和低价全包上的绝对诉求越强，风险越高。","high_score_signals":["接受真实边界","接受正常赔付与税费规则"],"low_score_signals":["要求全额赔付","要求低价全包"],"score_rule":"接受真实边界时高分。"}]}
