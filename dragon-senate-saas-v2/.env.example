# ----------------------------
# Local full-stack defaults
TZ=Asia/Shanghai
DEPLOY_REGION=cn-shanghai
STORAGE_REGION=cn-shanghai
DATA_RESIDENCY=cn-mainland
PRIMARY_CLOUD_VENDOR=aliyun
# ══════════════════════════════════════════════════════════
# 龙虾元老院统一配置文件
# 借鉴 openclaw-docker-cn-im 的配置驱动模式
# 一个 .env 控制所有组件
# ══════════════════════════════════════════════════════════

# ----------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=dragon_db
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/dragon_db
REDIS_URL=redis://redis:6379/0

QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=viral_formulas
QDRANT_PER_USER_COLLECTION=true
QDRANT_PREFER_GRPC=false
QDRANT_ENABLE_BINARY_QUANTIZATION=true
RAG_ANYTHING_ENABLED=false
RAG_ANYTHING_WORKDIR=./raganything_workdir
LOCAL_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
LOCAL_EMBEDDING_DIM=384

# ----------------------------
# LLM routing (local-first)
# ----------------------------
# ── 基础 LLM 配置 ──
API_KEY=your-api-key-here
BASE_URL=https://api.openai.com/v1
MODEL_ID=gpt-4o
API_PROTOCOL=openai
CONTEXT_WINDOW=128000
MAX_TOKENS=8192

# ── 备用 Provider 2 (可选) ──
# MODEL2_NAME=deepseek
# MODEL2_MODEL_ID=deepseek-chat
# MODEL2_BASE_URL=https://api.deepseek.com/v1
# MODEL2_API_KEY=
# MODEL2_PROTOCOL=openai

LOCAL_LLM_BASE_URL=http://ollama:11434/v1
LOCAL_LLM_MODEL=qwen3:59b
LOCAL_LLM_API_KEY=ollama

# Cloud fallback (DashScope OpenAI-compatible)
CLOUD_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
CLOUD_LLM_MODEL=qwen-flash
DASHSCOPE_API_KEY=
CLOUD_LLM_VENDOR=deepseek
LLM_CLOUD_PROVIDER_ORDER=deepseek,dashscope,volcengine

# Optional DeepSeek route (OpenAI-compatible)
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_API_KEY=

# Optional Volcengine Ark route (OpenAI-compatible)
VOLCENGINE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
VOLCENGINE_MODEL=
VOLCENGINE_API_KEY=

# Local fallback chain
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3:59b
LLM_MOCK_ENABLED=false
LLM_MOCK_FORCE=false

LLM_FORCE_LOCAL=false
LLM_ENABLE_CLOUD_FALLBACK=true
LLM_TEMPERATURE=0.3
LLM_REQUEST_TIMEOUT_SEC=90
LLM_MAX_RETRIES=1

# Optional external smart router (ClawRouter-style)
CLAWROUTER_ENABLED=false
CLAWROUTER_BASE_URL=http://127.0.0.1:8402
CLAWROUTER_ROUTE_PATH=/v1/route
CLAWROUTER_API_KEY=
CLAWROUTER_TIMEOUT_SEC=2.5
CLAWROUTER_FREE_MODEL=
CLAWROUTER_ECO_MODEL=
CLAWROUTER_PREMIUM_MODEL=
CLAWROUTER_LOW_RISK_TASK_TYPES=echo_reply,engagement_copy,radar_cleaning,strategist_clustering,intent_tagging,trend_scan,comment_hint,reply_draft,routine,llm_smoke,deepseek_smoke,health_check,status_query,trace_summary,metrics_snapshot,memory_hits
CLAWROUTER_ECO_TASK_TYPES=strategy_planning,content_generation,competitor_analysis,competitor_formula_analyzer,rag_ingest,dispatch_plan,dm_followup,general,dispatcher,hotspot_investigation,lead_scoring,trace_aggregate,replay_audit_summary,policy_bandit_update,persona_mask_apply,edge_skill_discovery,webhook_delivery
CLAWROUTER_PREMIUM_TASK_TYPES=sales_followup,followup_voice,multimodal_heavy,critical_conversion,long_script,human_approval_gate,compliance_review,legal_review,voice_call_realtime,cross_tenant_write,financial_settlement,risk_override

# Deterministic FollowUp sub-agent spawning (OpenClaw-style)
FOLLOWUP_DETERMINISTIC_SPAWN_ENABLED=true
FOLLOWUP_SUBAGENT_THRESHOLD=6
FOLLOWUP_MAX_CHILDREN=10
FOLLOWUP_LEADS_PER_CHILD=2
FOLLOWUP_CHILD_CONCURRENCY=2
FOLLOWUP_SUBAGENT_DB_PATH=./data/followup_subagents.sqlite

# Cost estimate for load test (CNY per 1M tokens)
CLOUD_INPUT_PRICE_PER_MTOK=0.3
CLOUD_OUTPUT_PRICE_PER_MTOK=0.6

# Optional legacy OpenAI key (embedding branch)
OPENAI_API_KEY=

# LangSmith / LangGraph tracing
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=dragon-senate-v3
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# ClawHub skill keys
CLAWHUB_KEYS={"radar":"skill_xxx","hotspot_investigation":"skill_xxx","strategist":"skill_xxx","competitor_analysis":"skill_xxx","competitor_formula_analyzer":"skill_xxx","rag_ingest_node":"skill_xxx","inkwriter":"skill_xxx","visualizer":"skill_xxx","dispatcher":"skill_xxx","distribute_to_edge":"skill_xxx","echoer":"skill_xxx","catcher":"skill_xxx","abacus":"skill_xxx","followup":"skill_xxx","feedback":"skill_xxx"}

# LibTV skill adapter (video factory 2.0)
LIBTV_ENABLED=false
LIBTV_ACCESS_KEY=
OPENAPI_IM_BASE=https://im.liblib.tv
LIBTV_TIMEOUT_SEC=30
LIBTV_POLL_INTERVAL_SEC=4
LIBTV_POLL_ROUNDS=8
LIBTV_CHANGE_PROJECT_EACH_RUN=false
LIBTV_MOCK_FORCE=false

# ComfyUI local video/image runtime (video factory 2.1)
# Provider order in visualizer: comfyui-local -> libtv-skill -> prompt-only
COMFYUI_ENABLED=false
COMFYUI_BASE_URL=http://127.0.0.1:8188
COMFYUI_TEMPLATE_ROOT=./workflow_templates
COMFYUI_TIMEOUT_SEC=30
COMFYUI_POLL_INTERVAL_SEC=2
COMFYUI_POLL_ROUNDS=20
COMFYUI_WORKFLOW_PATH=
COMFYUI_WORKFLOW_JSON=
COMFYUI_NEGATIVE_PROMPT=low quality, bad anatomy, watermark, blurry, distorted, artifact
COMFYUI_SEED=42
COMFYUI_WIDTH=1024
COMFYUI_HEIGHT=576
COMFYUI_STEPS=25
COMFYUI_MOCK_FORCE=false
# Optional industry workflow mapping (auto-selected by task tags)
COMFYUI_WORKFLOW_PATH_HOTEL=
COMFYUI_WORKFLOW_PATH_RESTAURANT=
COMFYUI_WORKFLOW_PATH_TCM=
COMFYUI_WORKFLOW_PATH_HOUSEKEEPING=
COMFYUI_WORKFLOW_PATH_BEAUTY=
COMFYUI_WORKFLOW_PATH_EDUCATION=
COMFYUI_WORKFLOW_PATH_FITNESS=
COMFYUI_WORKFLOW_PATH_RETAIL=

# Auth
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRE_MINUTES=120
PUBLIC_BASE_URL=
MOBILE_APPROVAL_BASE_URL=
APP_USERS_JSON=[{"username":"admin","password":"change_me","tenant_id":"tenant_demo","roles":["admin"]}]
AUTH_DATABASE_URL=
AUTH_BOOTSTRAP_ADMIN_EMAIL=admin@liaoyuan.example.com
AUTH_BOOTSTRAP_ADMIN_PASSWORD=ChangeMe123!
AUTH_BOOTSTRAP_ADMIN_USERNAME=admin
AUTH_BOOTSTRAP_ADMIN_TENANT=tenant_demo
AUTH_NOTIFICATION_MODE=file
AUTH_NOTIFICATION_DIR=./tmp/auth_notifications
AUTH_RESET_BASE_URL=http://127.0.0.1:3301/reset-password
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_STARTTLS=true
SMTP_SSL=false
SMS_MOCK_ENABLED=true
SMS_PROVIDER_WEBHOOK=
BILLING_DATABASE_URL=
BILLING_DEFAULT_PLAN=free
BILLING_DEFAULT_CYCLE=month
BILLING_GUARD_ENABLED=true
BILLING_GUARDED_PATHS=/run-dragon-team,/analyze_competitor_formula,/receive_dm_from_edge
BILLING_MOCK_WEBHOOK_SECRET=billing-mock-secret
BILLING_EST_PRICE_PER_MTOK_CNY=0.45
PLAN_FREE_TOKEN_LIMIT=300000
PLAN_FREE_RUN_LIMIT=120
PLAN_PRO_TOKEN_LIMIT=10000000
PLAN_PRO_RUN_LIMIT=3000
PLAN_PRO_PRICE_MONTH_CNY=499
PLAN_PRO_PRICE_YEAR_CNY=4990
PLAN_ENTERPRISE_TOKEN_LIMIT=100000000
PLAN_ENTERPRISE_RUN_LIMIT=50000
PLAN_ENTERPRISE_PRICE_MONTH_CNY=4999
PLAN_ENTERPRISE_PRICE_YEAR_CNY=49990
PAYMENT_PROVIDER=stripe
PAYMENT_ALLOW_SANDBOX_CHECKOUT=true
PAYMENT_RETURN_URL=http://127.0.0.1:3301/billing/return
PAYMENT_WEBHOOK_HMAC_SECRET=
STRIPE_SECRET_KEY=
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
WECHATPAY_MCH_ID=
WECHATPAY_PRIVATE_KEY=
WECHATPAY_SERIAL_NO=
ALLOW_INMEMORY_CHECKPOINTER=false

# Edge security
EDGE_SHARED_SECRET=edge-demo-secret
HITL_SHARED_SECRET=edge-demo-secret
HITL_ENABLED=true
HITL_WAIT_TIMEOUT_SEC=300

# Cloudflare Tunnel:
# 1) Fill token for named tunnel stable domain
# 2) Keep empty to use quick tunnel random domain
CF_TUNNEL_TOKEN=

# Telegram bot gateway
TELEGRAM_BOT_TOKEN=
TELEGRAM_BACKEND_BASE_URL=http://app:8000
TELEGRAM_RATE_LIMIT_PER_MIN=20
TELEGRAM_MEMORY_MAX_ITEMS=300
TELEGRAM_APPROVAL_CHAT_ID=
TELEGRAM_BACKEND_BEARER=

# Feishu gateway (recommended mainland primary channel)
FEISHU_ENABLED=false
FEISHU_REPLY_MODE=webhook
FEISHU_BOT_WEBHOOK=
FEISHU_APPROVAL_CHAT_ID=
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFY_SIGNATURE=false
FEISHU_SIGNING_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_ACCOUNTS_JSON=

# DingTalk gateway (fallback / enterprise channel)
DINGTALK_ENABLED=false
DINGTALK_REPLY_MODE=webhook
DINGTALK_BOT_WEBHOOK=
DINGTALK_APPROVAL_CHAT_ID=
DINGTALK_SESSION_WEBHOOK=
DINGTALK_VERIFY_SIGNATURE=false
DINGTALK_SIGNING_SECRET=
DINGTALK_VERIFICATION_TOKEN=
DINGTALK_ACCOUNTS_JSON=

# Chat webhook replay defense
CHAT_WEBHOOK_REPLAY_WINDOW_SEC=300

# AnythingLLM integration (optional)
ANYTHINGLLM_BASE_URL=http://127.0.0.1:3002
ANYTHINGLLM_API_KEY=
ANYTHINGLLM_EMBED_SCRIPT_URL=https://cdn.jsdelivr.net/npm/@mintplex-labs/anythingllm-embed/dist/embed.js
ANYTHINGLLM_EMBED_API_BASE=http://127.0.0.1:3002

# Client update signature verify / key rotation
CLIENT_UPDATE_REQUIRE_SIGNATURE=true
CLIENT_UPDATE_SIGNATURE_DEFAULT_KEY_ID=default
CLIENT_UPDATE_SIGNATURE_KEYS_JSON={"default":"-----BEGIN PUBLIC KEY-----\\n...\\n-----END PUBLIC KEY-----"}

# Edge runtime update verification
AUTO_UPDATE_REQUIRE_SIGNATURE=true
AUTO_UPDATE_DEFAULT_KEY_ID=default
AUTO_UPDATE_PUBLIC_KEYS_JSON={"default":"-----BEGIN PUBLIC KEY-----\\n...\\n-----END PUBLIC KEY-----"}

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Edge CLI / SKILL discovery
EDGE_SKILLS_DIR=./skills
EDGE_SKILL_MANIFEST_PATH=
EDGE_CLI_ANYTHING_BOOTSTRAP=false
EDGE_CLI_ANYTHING_REPO=https://github.com/HKUDS/CLI-Anything.git
EDGE_CLI_ANYTHING_DIR=./cli-anything
EDGE_CLI_ANYTHING_PIPELINE=
PKGX_BIN=pkgx
PKGX_DIR=~/.pkgx
PKGX_CACHE_DIR=~/.pkgx
EDGE_PKGX_DEFAULT_PACKAGES=+bash +coreutils +curl +git
EDGE_PKGX_EXEC_TIMEOUT_SEC=120
EDGE_COMMAND_DENY_PATTERNS=rm -rf, mkfs, shutdown, reboot, format , del /f /q, :(){
EDGE_COMMAND_ALLOW_REGEX=

# ClawWork-style economy controls
CLAWWORK_ECONOMY_ENABLED=false
CLAWWORK_DB_PATH=./data/clawwork_economy.sqlite
CLAWWORK_INITIAL_BALANCE_CNY=5.0
CLAWWORK_MIN_BALANCE_CNY=0.5
CLAWWORK_REWARD_PER_SUCCESS_CNY=0.03
CLAWWORK_LOCAL_COST_PER_MTOK_CNY=0.02

# lossless memory
LOSSLESS_MEMORY_DB_PATH=./data/lossless_memory.sqlite

# ClawTeam lightweight inbox/worktree simulation
CLAWTEAM_DB_PATH=./data/clawteam_inbox.sqlite

# Industry KB Pool (tenant-scoped industry knowledge database)
INDUSTRY_KB_DB_PATH=./data/industry_kb_pool.sqlite
INDUSTRY_KB_MIN_QUALITY_SCORE=45
INDUSTRY_KB_MIN_CONTENT_LEN=24
INDUSTRY_KB_MIN_TITLE_LEN=4
INDUSTRY_KB_MIN_EFFECT_SCORE=0

# OpenClaw-RL-inspired online policy bandit
POLICY_BANDIT_ENABLED=true
POLICY_BANDIT_DB_PATH=./data/policy_bandit.sqlite
POLICY_BANDIT_EPSILON=0.18
POLICY_BANDIT_WEIGHT_CONVERSION=0.60
POLICY_BANDIT_WEIGHT_REPLAY_SUCCESS=0.30
POLICY_BANDIT_WEIGHT_COMPLAINT=0.10

# Installer/update chain
DRAGON_UPDATE_MANIFEST_URL=
DRAGON_UPDATE_REQUIRE_SIGNATURE=true
DRAGON_UPDATE_DEFAULT_KEY_ID=default
DRAGON_UPDATE_KEYS_JSON={"default":"-----BEGIN PUBLIC KEY-----\\n...\\n-----END PUBLIC KEY-----","dev-hmac":"hmac:dev-secret"}
DRAGON_UPDATE_APPLY_GIT_PULL=false

# ── Agent Reach 全网搜索 ──
# 参考: https://github.com/Panniantong/Agent-Reach
# 借鉴: https://github.com/justlovemaki/openclaw-docker-cn-im
AGENT_REACH_ENABLED=false
AGENT_REACH_MODE=api
AGENT_REACH_API_URL=http://localhost:8050
AGENT_REACH_USE_CN_MIRROR=true

# ── 多账号管理 (JSON 格式) ──
# 每个渠道支持多账号，格式为 JSON 数组
# 优先使用 *_ACCOUNTS_JSON，否则用单账号环境变量
#
# 飞书多账号示例:
# FEISHU_ACCOUNTS_JSON=[{"id":"beauty_bot","name":"美妆部","tenant_id":"tenant_001","app_id":"cli_xxx","app_secret":"xxx"},{"id":"tech_bot","name":"科技部","tenant_id":"tenant_002","app_id":"cli_yyy","app_secret":"yyy"}]
#
# 钉钉多账号示例:
# DINGTALK_ACCOUNTS_JSON=[{"id":"main_bot","client_id":"xxx","client_secret":"xxx","robot_code":"xxx"}]
#
# 企微多账号示例:
# WECOM_ACCOUNTS_JSON=[{"id":"cs_bot","name":"客服机器人","bot_id":"xxx","secret":"xxx","corp_id":"xxx"}]
WECOM_ACCOUNTS_JSON=

# ── Docker 部署模式 ──
# DOCKER_MODE=true
# DOCKER_BIND=0.0.0.0
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_API_KEY=
CLOUD_LLM_VENDOR=openai
LLM_CLOUD_PROVIDER_ORDER=openai,deepseek,dashscope,volcengine
PROVIDER_FAILOVER_ORDER=openai,deepseek,dashscope,volcengine,local_ollama
