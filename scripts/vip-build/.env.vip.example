# Cloud C&C base URL (without socket path)
C_AND_C_SERVER_URL=http://127.0.0.1:3000

# Socket.io path. Default in current protocol is /fleet
SOCKETIO_PATH=/fleet

# JWT issued by backend (must include tenantId)
CLIENT_DEVICE_TOKEN=eyJhbGciOi...

# Unique machine code / node id
MACHINE_CODE=VIP-CLIENT-001
# NODE_ID=VIP-CLIENT-001

# Optional explicit tenant scope (overrides token payload for local debug only)
# TENANT_ID=tenant_demo

# Client version and optional update check
APP_VERSION=0.1.0
# AUTO_UPDATE_MANIFEST_URL=http://127.0.0.1:3000/api/v1/client-updates/latest?platform=win-x64&channel=stable
# AUTO_UPDATE_DOWNLOAD=false
# AUTO_UPDATE_REQUIRE_SIGNATURE=true
# AUTO_UPDATE_DEFAULT_KEY_ID=default
# AUTO_UPDATE_PUBLIC_KEY_PATH=./keys/release-public.pem
# AUTO_UPDATE_PUBLIC_KEYS_PATH=./keys/release-public-keys.json
# AUTO_UPDATE_PUBLIC_KEYS_JSON={"default":"-----BEGIN PUBLIC KEY-----\\n...\\n-----END PUBLIC KEY-----"}
# UPDATE_CHECK_ONLY=false
