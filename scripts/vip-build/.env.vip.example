# 一号客户特供 — 复制为 .env.vip 并填真实值（勿提交 Git）
# WebSocket 基址（不含 path）
C_AND_C_SERVER_URL=http://你的总控域名或IP:3000
# 若 Nest Socket.io 挂在 /agent-cc，多数 adapter 仍用 /socket.io；不对再改
# SOCKETIO_PATH=/socket.io
# 后端用同一 JWT_SECRET 签发的长效 Token，payload 含 tenantId
CLIENT_DEVICE_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# 与 ClientDevice / x-machine-code 一致，且已白名单
MACHINE_CODE=VIP-CLIENT-001
