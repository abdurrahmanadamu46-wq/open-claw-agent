# ===== Unified stack (web + backend + ai-subservice) =====

# Backend
JWT_SECRET=change_me_please_at_least_16_chars
NEW_API_BASE_URL=http://127.0.0.1:39999
NEW_API_TOKEN=dev_local_token
COMPLIANCE_REQUIRE_HITL=true

# AI subservice access from backend
DRAGON_AI_BASE_URL=http://ai-subservice:8000
DRAGON_AI_TIMEOUT_MS=90000
DRAGON_AI_SERVICE_USERNAME=admin
DRAGON_AI_SERVICE_PASSWORD=change_me

# AI subservice runtime
DRAGON_AI_JWT_SECRET=change_me_please_at_least_16_chars
DRAGON_AI_HITL_ENABLED=true
EDGE_SHARED_SECRET=edge-demo-secret
HITL_SHARED_SECRET=edge-demo-secret

# Shared infra
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=dragon_db
LOCAL_LLM_MODEL=qwen3:59b
POSTGRES_HOST_PORT=15432
REDIS_HOST_PORT=16379
QDRANT_HTTP_HOST_PORT=16333
QDRANT_GRPC_HOST_PORT=16334
OLLAMA_HOST_PORT=11444

# AI subservice build/runtime mode
DRAGON_AI_INSTALL_HEAVY=0
DRAGON_AI_RAG_ANYTHING_ENABLED=false

# Control-plane host ports
BACKEND_HOST_PORT=48789
WEB_HOST_PORT=3301

# Web runtime
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:48789
NEXT_PUBLIC_RUNTIME_ENV=production
NEXT_PUBLIC_USE_MOCK=false
NEXT_PUBLIC_DASHBOARD_ALLOW_MOCK_FALLBACK=false

# Optional profiles
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
CF_TUNNEL_TOKEN=

# ===== Full server deployment (docker-compose.full.yml) =====
REDIS_PORT=6379
QDRANT_PORT=6333
DRAGON_SENATE_PORT=18000
POLICY_ROUTER_PORT=8010
LOBSTER_MEMORY_PORT=8000
TRUST_VERIFY_PORT=8020
CTI_ENGINE_PORT=8030
XAI_SCORER_PORT=8040
BACKEND_PORT=48789
WEB_PORT=3301

# Optional China channels / external data sources
FEISHU_ENABLED=false
DINGTALK_ENABLED=false
WECOM_ENABLED=false
AGENT_REACH_ENABLED=false
