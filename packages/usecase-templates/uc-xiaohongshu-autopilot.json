{
  "id": "uc-xiaohongshu-autopilot",
  "name": "小红书内容自动化",
  "name_en": "Xiaohongshu Content Autopilot",
  "category": "social_media",
  "difficulty": "intermediate",
  "description": "从热点发现、文案生成、封面制作到定时发布的小红书全流程自动化。",
  "pain_point": "账号日更需要持续选题和封面设计，运营团队很容易被内容生产链路拖慢。",
  "lobsters": ["radar", "inkwriter", "visualizer", "dispatcher"],
  "skills_required": ["radar_hotspot_monitor", "inkwriter_copy_generate", "visualizer_cover_design", "dispatcher_scheduled_publish"],
  "channels": ["xiaohongshu"],
  "setup_steps": [
    {
      "step": 1,
      "action": "接入小红书账号",
      "code_type": "config",
      "code": "在控制台的渠道管理里添加小红书账号，并完成扫码登录。",
      "requires_user_input": true
    },
    {
      "step": 2,
      "action": "填写账号定位",
      "code_type": "prompt",
      "code": "输入账号垂类、目标人群和品牌调性，供触须虾持续追踪热点。",
      "requires_user_input": true
    },
    {
      "step": 3,
      "action": "选择发布频率",
      "code_type": "config",
      "code": "建议设置为每天 1-3 篇，并预留人工审核环节。",
      "requires_user_input": true
    },
    {
      "step": 4,
      "action": "启用自动流程",
      "code_type": "none",
      "code": "系统会串起触须虾追热点、吐墨虾写文案、幻影虾做封面、点兵虾定时发布。",
      "requires_user_input": false
    }
  ],
  "scheduler_config": {
    "kind": "cron",
    "schedule": "0 9 * * *",
    "session_mode": "isolated"
  },
  "tips": [
    "建议每篇内容都保留人工终审，降低平台风控概率。",
    "优先让金算虾回看高收藏率主题，再放大到更多账号。",
    "初期不要超过每天 3 篇，先跑通稳定节奏。"
  ],
  "estimated_cost_per_run": "$0.15-0.30",
  "tags": ["中国平台", "内容工厂", "社交媒体", "定时发布"]
}
