{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lobsterpool.local/schemas/visualizer/storyboard-pack.schema.json",
  "title": "StoryboardPack Schema",
  "type": "object",
  "required": [
    "goal",
    "assumptions",
    "evidence",
    "confidence",
    "riskLevel",
    "nextAction",
    "cover_direction",
    "shot_list",
    "asset_dependencies",
    "execution_feasibility_score"
  ],
  "properties": {
    "goal": {
      "type": "string"
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "riskLevel": {
      "type": "string"
    },
    "nextAction": {
      "type": "string"
    },
    "cover_direction": {
      "type": "string"
    },
    "shot_list": {
      "type": "string"
    },
    "asset_dependencies": {
      "type": "string"
    },
    "execution_feasibility_score": {
      "type": "string"
    }
  },
  "additionalProperties": true
}