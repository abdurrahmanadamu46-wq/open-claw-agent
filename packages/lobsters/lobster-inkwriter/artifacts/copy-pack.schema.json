{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lobsterpool.local/schemas/inkwriter/copy-pack.schema.json",
  "title": "CopyPack Schema",
  "type": "object",
  "required": [
    "goal",
    "assumptions",
    "evidence",
    "confidence",
    "riskLevel",
    "nextAction",
    "core_message",
    "hooks",
    "script_body",
    "risk_phrases"
  ],
  "properties": {
    "goal": {
      "type": "string"
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "riskLevel": {
      "type": "string"
    },
    "nextAction": {
      "type": "string"
    },
    "core_message": {
      "type": "string"
    },
    "hooks": {
      "type": "string"
    },
    "script_body": {
      "type": "string"
    },
    "risk_phrases": {
      "type": "string"
    }
  },
  "additionalProperties": true
}