    "mission_memory",
    "tenant_memory"
  ],
  "evalFocus": [
    "allocation_quality",
    "risk_control",
    "resource_fairness",
    "merge_quality"
  ],
  "upstreamRoles": [],
  "downstreamRoles": [
    "radar",
