{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lobsterpool.local/schemas/strategist/strategy-route.schema.json",
  "title": "StrategyRoute Schema",
  "type": "object",
  "required": [
    "goal",
    "assumptions",
    "evidence",
    "confidence",
    "riskLevel",
    "nextAction",
    "primary_route",
    "alternative_routes",
    "priority_order",
    "risk_tradeoff"
  ],
  "properties": {
    "goal": {
      "type": "string"
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "riskLevel": {
      "type": "string"
    },
    "nextAction": {
      "type": "string"
    },
    "primary_route": {
      "type": "string"
    },
    "alternative_routes": {
      "type": "string"
    },
    "priority_order": {
      "type": "string"
    },
    "risk_tradeoff": {
      "type": "string"
    }
  },
  "additionalProperties": true
}