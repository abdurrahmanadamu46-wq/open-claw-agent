{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lobsterpool.local/schemas/dispatcher/execution-plan.schema.json",
  "title": "ExecutionPlan Schema",
  "type": "object",
  "required": [
    "goal",
    "assumptions",
    "evidence",
    "confidence",
    "riskLevel",
    "nextAction",
    "task_graph",
    "routing_targets",
    "retry_policy",
    "fallback_plan"
  ],
  "properties": {
    "goal": {
      "type": "string"
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "riskLevel": {
      "type": "string"
    },
    "nextAction": {
      "type": "string"
    },
    "task_graph": {
      "type": "string"
    },
    "routing_targets": {
      "type": "string"
    },
    "retry_policy": {
      "type": "string"
    },
    "fallback_plan": {
      "type": "string"
    }
  },
  "additionalProperties": true
}