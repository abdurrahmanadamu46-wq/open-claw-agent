{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lobsterpool.local/schemas/radar/signal-brief.schema.json",
  "title": "SignalBrief Schema",
  "type": "object",
  "required": [
    "goal",
    "assumptions",
    "evidence",
    "confidence",
    "riskLevel",
    "nextAction",
    "signal_summary",
    "source_reliability",
    "impact_level",
    "recommended_attention"
  ],
  "properties": {
    "goal": {
      "type": "string"
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "riskLevel": {
      "type": "string"
    },
    "nextAction": {
      "type": "string"
    },
    "signal_summary": {
      "type": "string"
    },
    "source_reliability": {
      "type": "string"
    },
    "impact_level": {
      "type": "string"
    },
    "recommended_attention": {
      "type": "string"
    }
  },
  "additionalProperties": true
}