{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lobsterpool.local/schemas/followup/follow-up-action-plan.schema.json",
  "title": "FollowUpActionPlan Schema",
  "type": "object",
  "required": [
    "goal",
    "assumptions",
    "evidence",
    "confidence",
    "riskLevel",
    "nextAction",
    "followup_stage",
    "contact_plan",
    "cadence_rule",
    "approval_requirements"
  ],
  "properties": {
    "goal": {
      "type": "string"
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "riskLevel": {
      "type": "string"
    },
    "nextAction": {
      "type": "string"
    },
    "followup_stage": {
      "type": "string"
    },
    "contact_plan": {
      "type": "string"
    },
    "cadence_rule": {
      "type": "string"
    },
    "approval_requirements": {
      "type": "string"
    }
  },
  "additionalProperties": true
}