{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lobsterpool.local/schemas/echoer/engagement-reply-pack.schema.json",
  "title": "EngagementReplyPack Schema",
  "type": "object",
  "required": [
    "goal",
    "assumptions",
    "evidence",
    "confidence",
    "riskLevel",
    "nextAction",
    "intent_guess",
    "emotion_state",
    "reply_text",
    "handoff_suggestion"
  ],
  "properties": {
    "goal": {
      "type": "string"
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "riskLevel": {
      "type": "string"
    },
    "nextAction": {
      "type": "string"
    },
    "intent_guess": {
      "type": "string"
    },
    "emotion_state": {
      "type": "string"
    },
    "reply_text": {
      "type": "string"
    },
    "handoff_suggestion": {
      "type": "string"
    }
  },
  "additionalProperties": true
}