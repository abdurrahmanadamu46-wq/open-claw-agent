{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lobsterpool.local/schemas/catcher/lead-assessment.schema.json",
  "title": "LeadAssessment Schema",
  "type": "object",
  "required": [
    "goal",
    "assumptions",
    "evidence",
    "confidence",
    "riskLevel",
    "nextAction",
    "intent_score",
    "fit_score",
    "risk_score",
    "lead_tier"
  ],
  "properties": {
    "goal": {
      "type": "string"
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "riskLevel": {
      "type": "string"
    },
    "nextAction": {
      "type": "string"
    },
    "intent_score": {
      "type": "string"
    },
    "fit_score": {
      "type": "string"
    },
    "risk_score": {
      "type": "string"
    },
    "lead_tier": {
      "type": "string"
    }
  },
  "additionalProperties": true
}