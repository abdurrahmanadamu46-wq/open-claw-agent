# 阿里云 RDS PostgreSQL 连接（生产）
DATABASE_URL=postgresql://rds_user:rds_password@rm-xxxxxx.pg.rds.aliyuncs.com:5432/dragon_db

# LLM 与技能配置
OPENAI_API_KEY=sk-xxx
CLAWHUB_KEYS={"radar":"skill_xxx","strategist":"skill_xxx","inkwriter":"skill_xxx","visualizer":"skill_xxx","dispatcher":"skill_xxx","echoer":"skill_xxx","catcher":"skill_xxx","abacus":"skill_xxx","followup":"skill_xxx","feedback":"skill_xxx"}

# JWT 登录
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRE_MINUTES=120

# 登录用户（JSON 数组）
# password 是明文示例，建议部署前替换为你自己的强密码
APP_USERS_JSON=[{"username":"admin","password":"change_me","tenant_id":"tenant_demo","roles":["admin"]}]
